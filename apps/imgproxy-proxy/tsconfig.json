{
  "display": "Default",
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "nodenext",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "incremental": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "tests"
  ],
  "ts-node": {
    "swc": true,
    "esm": true
  },
}